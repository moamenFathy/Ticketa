@model RoleUpsertVM

@{
    var isEdit = !string.IsNullOrEmpty(Model.Id);
    var title = isEdit ? "Edit Role" : "Create Role";
}

<!-- Header -->
<div class="flex items-center justify-between pb-3 border-b border-base-300">
    <h3 class="text-xl font-bold">@title</h3>
    <label for="modal" class="btn btn-sm btn-ghost btn-circle hover:bg-base-300">✕</label>
</div>

<!-- Form -->
<form class="flex flex-col gap-4 mt-4"
      id="roleForm"
      method="post"
      asp-action="Upsert"
      asp-controller="Role"
      data-submit-url="/Role/Upsert">

    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <!-- Validation -->
    <div asp-validation-summary="ModelOnly"
         class="text-error text-sm bg-error/10 p-2 rounded-lg"></div>

    <!-- Role Name -->
    <label class="form-control w-full">
        <span class="label-text font-medium">Role Name</span>
        <input asp-for="Name"
               class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary"
               placeholder="e.g. Content Manager"
               autofocus />
        <span asp-validation-for="Name" class="text-error mt-1 text-sm font-bold"></span>
    </label>

    <!-- Is Admin Role -->
    <label class="label cursor-pointer justify-start gap-3">
        <input asp-for="IsAdminRole" type="checkbox" class="checkbox checkbox-primary" />
        <span class="label-text font-medium">Admin Role (appears in admin user management)</span>
    </label>

    <!-- Permissions -->
    <div class="border-t border-base-300 pt-3">
        <span class="text-sm font-semibold text-base-content/70 uppercase tracking-wide">Permissions</span>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
            @foreach (var group in Model.AllPermissionsGrouped)
            {
                var groupClass = "perm-group-" + group.Key;
                <div class="card border border-base-300 rounded-box">
                    <div class="card-body p-3">
                        <div class="flex items-center justify-between border-b border-base-200 pb-2">
                            <span class="text-sm font-bold">@group.Key</span>
                            <label class="label cursor-pointer gap-1.5 p-0">
                                <span class="label-text text-xs font-medium">Select All</span>
                                <input type="checkbox"
                                       class="checkbox checkbox-xs checkbox-primary select-all"
                                       data-group="@groupClass" />
                            </label>
                        </div>
                        <div class="flex flex-col gap-0.5 mt-2">
                            @foreach (var permission in group.Value)
                            {
                                var isChecked = Model.SelectedPermissions.Contains(permission);
                                <label class="label cursor-pointer gap-2 justify-start py-1.5 px-1 rounded hover:bg-base-200/50">
                                    <input type="checkbox"
                                           name="SelectedPermissions"
                                           value="@permission"
                                           class="checkbox checkbox-sm checkbox-primary perm-check @groupClass"
                                           checked="@isChecked" />
                                    <span class="label-text text-sm capitalize">@permission.Split(':').Last()</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Actions -->
    <div class="modal-action mt-2 flex justify-end gap-3">
        <label for="modal" class="btn btn-ghost border border-base-300 hover:bg-base-200">Cancel</label>
        <button class="btn btn-primary px-5 hover:brightness-110" type="submit">@(isEdit ? "Save Changes" : "Create Role")</button>
    </div>
</form>
