@model AdminUserUpsertVM

@{
    var isEdit = !string.IsNullOrEmpty(Model.Id);
    var title = isEdit ? "Edit User" : "Create User";
    var submitUrl = isEdit
      ? "/AdminUserManagement/Upsert?id=" + Model.Id
      : "/AdminUserManagement/Upsert";
}

<!-- Header -->
<div class="flex items-center justify-between pb-3 border-b border-base-300">
    <h3 class="text-xl font-bold">@title</h3>
    <label for="modal" class="btn btn-sm btn-ghost btn-circle hover:bg-base-300">✕</label>
</div>

<!-- Form -->
<form class="flex flex-col gap-4 mt-4"
      id="userForm"
      method="post"
      asp-action="Upsert"
      asp-controller="AdminUserManagement"
      data-submit-url="@submitUrl">

    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <!-- Validation -->
    <div asp-validation-summary="ModelOnly"
         class="text-error text-sm bg-error/10 p-2 rounded-lg"></div>

    <!-- Name -->
    <div class="grid grid-cols-2 gap-4">
        <label class="form-control w-full">
            <span class="label-text font-medium">First Name</span>
            <input asp-for="FirstName"
                   class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="First name"
                   autofocus />
            <span asp-validation-for="FirstName" class="text-error mt-1 text-sm font-bold"></span>
        </label>

        <label class="form-control w-full">
            <span class="label-text font-medium">Last Name</span>
            <input asp-for="LastName"
                   class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="Last name" />
            <span asp-validation-for="LastName" class="text-error mt-1 text-sm font-bold"></span>
        </label>
    </div>

    <!-- Email -->
    <label class="form-control w-full">
        <span class="label-text font-medium">Email</span>
        <input asp-for="Email"
               class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary"
               placeholder="Email address" />
        <span asp-validation-for="Email" class="text-error mt-1 text-sm font-bold"></span>
    </label>

    <!-- Passwords -->
    <div class="grid grid-cols-2 gap-4">
        <!-- Password Field -->
        <div class="form-control relative">
            <label asp-for="Password" class="label pb-1">
                <span class="label-text font-medium text-black">@(isEdit ? "New Password" : "Password")</span>
            </label>
            <div class="input input-bordered w-full focus-within:outline-none focus-within:ring-2 focus-within:ring-primary flex items-center gap-3">
                <input asp-for="Password" id="Password" type="password" class="grow min-w-0" placeholder="@(isEdit ? "Leave blank to keep current" : "Minimum 8 characters")" />
                <button type="button" class="cursor-pointer p-1.5 hover:bg-base-content/10 text-base-content/70 rounded-full transition-colors shrink-0" onclick="togglePassword('Password', this)">
                    <svg class="w-5 h-5 toggle-eye" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                    <svg class="w-5 h-5 toggle-eye-slash hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-error text-xs font-bold mt-1 px-1 opacity-90"></span>
        </div>

        <!-- Confirm Password Field -->
        <div class="form-control relative">
            <label asp-for="ConfirmPassword" class="label pb-1">
                <span class="label-text font-medium text-black">Confirm</span>
            </label>
            <div class="input input-bordered w-full focus-within:outline-none focus-within:ring-2 focus-within:ring-primary flex items-center gap-3">
                <input asp-for="ConfirmPassword" id="ConfirmPassword" type="password" class="grow min-w-0" placeholder="Confirm password" />
                <button type="button" class="cursor-pointer p-1.5 hover:bg-base-content/10 text-base-content/70 rounded-full transition-colors shrink-0" onclick="togglePassword('ConfirmPassword', this)">
                    <svg class="w-5 h-5 toggle-eye" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                    <svg class="w-5 h-5 toggle-eye-slash hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-error text-xs font-bold mt-1 px-1 opacity-90"></span>
        </div>
    </div>

    <!-- Role -->
    <label class="form-control w-full">
        <span class="label-text font-medium">Role</span>
        <select asp-for="Role"
                class="select select-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary">
            <option value="">-- Select Role --</option>
            @foreach (var role in Model.AvailableRoles)
            {
                <option value="@role" selected="@(Model.Role == role)">@role</option>
            }
        </select>
        <span asp-validation-for="Role" class="text-error mt-1 text-sm font-bold"></span>
    </label>

    <!-- Actions -->
    <div class="modal-action mt-2 flex justify-end gap-3">
        <label for="modal" class="btn btn-ghost border border-base-300 hover:bg-base-200">Cancel</label>
        <button class="btn btn-primary px-5 hover:brightness-110" type="submit">@(isEdit ? "Save Changes" : "Create User")</button>
    </div>
</form>
