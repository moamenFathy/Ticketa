@model Ticketa.Core.DTOs.HallUpsertDto
@using Ticketa.Core.Enums
@using Ticketa.Core.Helpers

@if (Model is null)
{
    <div>
        <h3 class="text-xl font-bold text-error">Hall not found</h3>
        <p class="mt-2 text-gray-500">No hall data was returned.</p>
        <div class="modal-action mt-4">
            <label for="modal" class="btn border border-base-300">Close</label>
        </div>
    </div>
}
else
{
    var template = HallTypeHelper.GetTemplate(Model.Type);

    <!-- Header -->
    <div class="flex items-center justify-between pb-3 border-b border-base-300">
        <h3 class="text-xl font-bold">Edit Hall</h3>
        <label for="modal" class="btn btn-sm btn-ghost btn-circle hover:bg-base-300">✕</label>
    </div>

    <!-- Form (name-only — type is immutable post-create) -->
    <form class="flex flex-col gap-4 mt-4"
          id="editForm"
          method="post"
          asp-controller="Hall"
          asp-action="Upsert"
          data-submit-url="/Hall/Upsert?id=@Model.Id">

        @Html.AntiForgeryToken()

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly"
             class="text-error text-sm bg-error/10 p-2 rounded-lg"></div>

        <!-- Hidden id for the DTO binding -->
        <input type="hidden" name="id" value="@Model.Id" />

        <!-- Name -->
        <label class="form-control w-full">
            <span class="label-text font-medium">Hall Name</span>
            <input asp-for="Name"
                   class="input input-bordered w-full focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="Enter hall name"
                   autofocus />
            <span asp-validation-for="Name" class="text-error mt-1 text-sm font-bold"></span>
        </label>

        <!-- Read-only type info -->
        <div class="rounded-xl border border-base-300 bg-base-200/50 p-3 text-sm">
            <p class="font-semibold mb-2 text-base-content/70">📐 Hall Layout (fixed)</p>
            <div class="grid grid-cols-3 gap-2 text-center">
                <div class="bg-base-100 rounded-lg p-2 border border-base-300">
                    <div class="text-lg font-bold text-primary">@template.Rows</div>
                    <div class="text-xs text-base-content/50">Rows</div>
                </div>
                <div class="bg-base-100 rounded-lg p-2 border border-base-300">
                    <div class="text-lg font-bold text-primary">@template.SeatsPerRow</div>
                    <div class="text-xs text-base-content/50">Seats / Row</div>
                </div>
                <div class="bg-base-100 rounded-lg p-2 border border-base-300">
                    <div class="text-lg font-bold text-primary">@(template.Rows * template.SeatsPerRow)</div>
                    <div class="text-xs text-base-content/50">Total Seats</div>
                </div>
            </div>
            <div class="mt-2 flex items-center gap-2">
                @{
                    string typeLabel = Model.Type switch
                    {
                        HallType.Standard => "🎬 Standard",
                        HallType.IMAX     => "🔭 IMAX",
                        HallType.Gold     => "⭐ Gold",
                        _                 => Model.Type.ToString()
                    };
                }
                <span class="badge badge-ghost text-xs">Type: @typeLabel</span>
                <span class="text-xs text-base-content/40">Type cannot be changed after creation</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="modal-action mt-2 flex justify-end gap-3">
            <label for="modal" class="btn btn-ghost border border-base-300 hover:bg-base-200">Cancel</label>
            <button class="btn btn-primary px-5 hover:brightness-110" type="submit">Save Changes</button>
        </div>

    </form>
}