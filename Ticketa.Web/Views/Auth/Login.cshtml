@model Ticketa.Web.ViewModels.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Ticketa</title>
    <link rel="stylesheet" href="~/Ticketa.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="bg-base-200">

<div class="relative min-h-screen flex items-center justify-center overflow-hidden bg-base-200 py-10 px-4 sm:px-6 lg:px-8">
    <!-- Abstract Ambient Background Shapes -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-primary/20 blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 rounded-full bg-secondary/20 blur-3xl"></div>
    </div>

    <!-- Glassmorphism Card -->
    <div class="card w-screen max-w-md shadow-2xl bg-base-100/80 backdrop-blur-xl border border-base-300 z-10">
        <div class="card-body p-8 sm:p-10">
            <!-- Header -->
            <div class="text-center mb-8">
                <h2 class="text-4xl font-extrabold tracking-tight mb-2">
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">Welcome Back</span>
                </h2>
                <p class="text-base-content/70">Sign in to your Ticketa account.</p>
            </div>

            <form asp-action="Login" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-error shadow-sm mb-4 text-sm rounded-lg"></div>

                <!-- Email Field -->
                <div class="form-control w-full">
                    <label asp-for="Email" class="label pb-1">
                        <span class="label-text font-semibold w-full">Email Address</span>
                    </label>
                    <label class="input flex items-center gap-3 focus-within:ring-2 focus-within:ring-primary/50 transition-all shadow-sm w-full validator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-50 shrink-0"><path d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" /><path d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" /></svg>
                        <input asp-for="Email" type="email" class="grow w-full" placeholder="you@example.com" autofocus />
                    </label>
                    <span asp-validation-for="Email" class="text-error text-xs font-bold mt-1 px-1 opacity-90"></span>
                </div>

                <!-- Password Field -->
                <div class="form-control hover:z-20">
                    <label asp-for="Password" class="label pb-1">
                        <span class="label-text font-semibold">Password</span>
                    </label>
                    <label class="input input-bordered flex items-center gap-3 focus-within:ring-2 focus-within:ring-primary/50 transition-all shadow-sm w-full overflow-hidden validator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-50 shrink-0"><path fill-rule="evenodd" d="M14 6a4 4 0 0 1-4.899 3.899l-1.955 1.955a.5.5 0 0 1-.353.146H5v1.5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-2.293a.5.5 0 0 1 .146-.353l3.955-3.955A4 4 0 1 1 14 6Zm-4-2a.75.75 0 0 0 0 1.5.5.5 0 0 1 .5.5.75.75 0 0 0 1.5 0 2 2 0 0 0-2-2Z" clip-rule="evenodd" /></svg>
                        <input asp-for="Password" id="Password" type="password" class="grow min-w-0" placeholder="••••••••" />
                        <label class="cursor-pointer p-1.5 hover:bg-base-content/10 text-base-content/70 rounded-full transition-colors shrink-0">
                            <input type="checkbox" class="hidden peer" tabindex="-1" onclick="togglePassword('Password')" />
                            <!-- Eye icon (off state => hidden password) -->
                            <svg class="w-5 h-5 peer-checked:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                            <!-- Eye slash icon (on state => visible password) -->
                            <svg class="w-5 h-5 hidden peer-checked:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                        </label>
                    </label>
                    <span asp-validation-for="Password" class="text-error text-xs font-bold mt-1 px-1 opacity-90"></span>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="form-control">
                    <label class="label cursor-pointer justify-start gap-3">
                        <input asp-for="RememberMe" type="checkbox" class="checkbox checkbox-primary checkbox-sm rounded-md" />
                        <span class="label-text font-medium text-base-content/80">Remember me</span>
                    </label>
                </div>

                <!-- Submit Button -->
                <div class="form-control mt-6">
                    <button type="submit" class="btn btn-primary w-full shadow-lg hover:shadow-primary/40 hover:-translate-y-0.5 transition-all text-base tracking-wide">
                        Sign In
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 ml-1"><path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" /></svg>
                    </button>
                </div>

                <!-- Divider & Register Link -->
                <div class="divider text-base-content/50 text-xs uppercase tracking-widest mt-6 mb-2">OR</div>
                <div class="text-center">
                    <span class="text-sm text-base-content/70">Don't have an account?</span> 
                    <a asp-action="Register" class="link link-primary font-bold hover:text-primary focus:outline-none transition-colors ml-1">Create one here</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<partial name="_ValidationScriptsPartial" />
<script src="~/js/passwordToggler.js" asp-append-version="true"></script>

</body>
</html>