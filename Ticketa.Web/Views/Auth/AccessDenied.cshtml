@{
    Layout = null;
}

<!DOCTYPE HTML>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - Ticketa</title>
    <link rel="stylesheet" href="~/Ticketa.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="bg-base-200">

    <div class="relative min-h-screen flex items-center justify-center overflow-hidden bg-base-200 py-10 px-4 sm:px-6 lg:px-8">
        <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
            <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-error/20 blur-3xl"></div>
            <div class="absolute bottom-10 left-10 w-80 h-80 rounded-full bg-warning/20 blur-3xl"></div>
        </div>

        <div class="card w-screen max-w-md shadow-2xl bg-base-100/80 backdrop-blur-xl border border-base-300 z-10">
            <div class="card-body p-8 sm:p-10 text-center">
                <div class="mx-auto mb-6 flex items-center justify-center w-20 h-20 rounded-full bg-error/10">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-error" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                </div>

                <h2 class="text-3xl font-extrabold tracking-tight mb-2">Access Denied</h2>
                <p class="text-base-content/70 mb-2">
                    You don't have permission to access this page.
                </p>
                <p class="text-sm text-base-content/50 mb-8">
                    If you believe this is a mistake, please contact your administrator.
                </p>

                <a href="/" class="btn btn-primary w-full shadow-lg hover:shadow-primary/40 hover:-translate-y-0.5 transition-all">
                    Return to Dashboard
                </a>

                <div class="mt-6 text-sm text-base-content/50">
                    <a asp-action="Logout" class="link link-hover text-error/70 hover:text-error transition-colors">Sign out</a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
